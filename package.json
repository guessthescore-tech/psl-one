{
  "name": "psl-one",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "codex:validate": "node scripts/validate-codex-project.mjs",
    "docs:validate": "node scripts/validate-docs.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "@fastify/middie": "9.3.2",
      "esbuild": "0.28.1",
      "fast-uri": "3.1.2",
      "form-data": "4.0.6",
      "glob": "10.5.0",
      "tmp": "0.2.7",
      "ws": "8.21.0"
    }
  }
}
