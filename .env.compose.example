# PSL One local production-equivalent Compose example.
# Copy to .env.compose for local container validation.
# Do not commit .env.compose.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=psl_identity_dev
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/psl_identity_dev
JWT_SECRET=replace-with-at-least-32-characters-for-local-compose
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3001

API_PORT=4000
WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

GIT_SHA=local
BUILD_TIMESTAMP=local
