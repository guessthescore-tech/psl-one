# Copy to terraform.tfvars only for an authorised Terraform plan/apply.
# Do NOT commit terraform.tfvars — it is in .gitignore.

aws_region  = "af-south-1"
environment = "beta"
project     = "psl-one"

# t2.micro is NOT offered in af-south-1 (Africa Cape Town) — t3.micro is required.
# GUARDRAIL BLOCKER: PSLOneSprint0DenyGuardrails (DenyNonFreeTierEC2) is effectively
# attached to psl-one-admin via PSLOneSprint0Infra group. Blocks ec2:RunInstances for
# t3.micro until amended. Do not apply until S3-INFRA-02E-IAM is approved.
# t3.micro: 2 vCPU, 1 GiB RAM — burstable credit instance, beta-only, charges apply.
instance_type    = "t3.micro"
root_volume_size = 20

# Mode A (restricted internal testing — default):
#   Restrict both port 80 and port 443 to reviewer IPs.
#   Add EC2 public IP to /etc/hosts on tester machines:
#     <EC2-IP>  api.staging.pslone.co.za  staging.pslone.co.za
allowed_beta_cidrs = ["YOUR_REVIEWER_IP/32"]

# Mode B (approved public HTTPS — requires explicit owner approval):
#   allowed_beta_cidrs = ["0.0.0.0/0"]
#   Also set create_elastic_ip = true and ensure DNS A records point to EC2 IP.

# Enable only after owner approval for Mode B or stable-IP image baking.
create_elastic_ip = false

api_domain = "api.staging.pslone.co.za"
web_domain  = "staging.pslone.co.za"

# Explicit subnet ID — required before apply (prevents nondeterministic ids[0] selection).
# Preferred: subnet-0972d64b0be296aa3 (af-south-1b). Change requires a fresh plan.
subnet_id = "subnet-0972d64b0be296aa3"

# Leave empty for SSM Session Manager access only (recommended).
key_pair_name = ""
