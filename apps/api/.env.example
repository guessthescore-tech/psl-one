# ─────────────────────────────────────────────────────────────────────────────
# PSL One API — environment variable contract
# Copy this file to .env and fill in real values. Never commit .env.
# All keys listed here are validated at startup by apps/api/src/env.ts
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
PORT=4000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/psl_identity_dev

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=                   # min 32 characters; generate with: openssl rand -hex 32

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Wildcards are rejected.
# Must be set in staging/production. Omit in development (localhost is allowed).
CORS_ORIGINS=https://beta.pslone.co.za,https://experience.pslone.co.za

# ── Application base URL ─────────────────────────────────────────────────────
# Used to construct email verification and password-reset links.
# Must be the public HTTPS origin users click from their inbox.
APP_BASE_URL=https://beta.pslone.co.za

# ── Email delivery ───────────────────────────────────────────────────────────
# EMAIL_PROVIDER options:
#   smtp    — send via nodemailer (staging / production)
#   console — log to stdout only (development)
#   null    — silent discard (CI / test)
EMAIL_PROVIDER=smtp

# SMTP — required when EMAIL_PROVIDER=smtp
# cPanel at mail.pslone.co.za requires port 465 with implicit SSL/TLS.
# Using port 587 (STARTTLS) or SMTP_SECURE=false will cause SMTP 535.
SMTP_HOST=mail.pslone.co.za
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@pslone.co.za
SMTP_PASSWORD=                # cPanel mailbox password — never commit
SMTP_FROM=PSL One <no-reply@pslone.co.za>

# ── AWS / Infrastructure ─────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCOUNT_ID=
SES_FROM_ADDRESS=no-reply@pslone.co.za
SES_REGION=af-south-1

# ── Data providers ───────────────────────────────────────────────────────────
# At least one provider key must be set for live fixture data.
# See docs/data-providers/ for procurement and activation instructions.
API_FOOTBALL_KEY=
FOOTBALL_DATA_API_KEY=
PARSE_API_KEY=
SPORTSRADAR_SOCCER_API_KEY=
SCOREBAT_VIDEO_API_ACCESS_TOKEN=
SCOREBAT_WIDGET_TOKEN=

# DATA_PROVIDER controls which adapter is active:
#   api-football | football-data-org | sportmonks | scorebat | parse-psl | noop
DATA_PROVIDER=noop

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=psl-local
KAFKA_GROUP_ID=psl-local-group

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Seeding (local dev only) ──────────────────────────────────────────────────
SEED_PLATFORM_ADMIN_EMAIL=admin@pslone.co.za
SEED_PLATFORM_ADMIN_PASSWORD=
SEED_PLATFORM_USER_EMAIL=
SEED_PLATFORM_USER_PASSWORD=
SEED_PLATFORM_PARTNER_EMAIL=
SEED_PLATFORM_PARTNER_PASSWORD=
