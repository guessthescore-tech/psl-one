  updatedAt                  DateTime             @updatedAt @map("updated_at")

  walletLinks                WalletLink[]
  walletTransactions         WalletTransaction[]

  @@map("wallet_provider_details")
}

model WalletLink {
  id                  String           @id @default(uuid())
  fanUserId           String           @map("fan_user_id")
  walletProviderId    String           @map("wallet_provider_id")
  providerCustomerRef String?          @map("provider_customer_ref")
  providerWalletRef   String?          @map("provider_wallet_ref")
  status              WalletLinkStatus @default(NOT_LINKED)
  kycStatus           WalletKycStatus  @default(UNKNOWN) @map("kyc_status")
  linkedAt            DateTime?        @map("linked_at")
  lastVerifiedAt      DateTime?        @map("last_verified_at")
  unlinkedAt          DateTime?        @map("unlinked_at")
  metadataJson        Json?            @map("metadata_json")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  walletProvider      WalletProviderDetail @relation(fields: [walletProviderId], references: [id])

  @@unique([fanUserId, walletProviderId])
  @@index([fanUserId])
  @@index([status])
  @@map("wallet_links")
}

model WalletTransaction {
  id                  String                  @id @default(uuid())
  walletProviderId    String                  @map("wallet_provider_id")
  fanUserId           String?                 @map("fan_user_id")
  walletLinkId        String?                 @map("wallet_link_id")
  transactionType     WalletTransactionType   @map("transaction_type")
  status              WalletTransactionStatus @default(CREATED)
  amount              Decimal?                @db.Decimal(18, 6)
  currency            String?
  providerReference   String?                 @map("provider_reference")
  idempotencyKey      String?                 @unique @map("idempotency_key")
  requestSummaryJson  Json?                   @map("request_summary_json")
  responseSummaryJson Json?                   @map("response_summary_json")
  errorCode           String?                 @map("error_code")
  errorMessage        String?                 @map("error_message")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  walletProvider      WalletProviderDetail    @relation(fields: [walletProviderId], references: [id])

  @@index([fanUserId])
  @@index([walletProviderId])
  @@index([transactionType])
  @@index([createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

// ── Campaign Analytics ─────────────────────────────────────────────────────────

model CampaignAnalyticsSnapshot {
  id                   String          @id @default(uuid())
  campaignId           String          @map("campaign_id")
  snapshotDate         DateTime        @map("snapshot_date") @db.Date
  impressions          Int             @default(0)
  uniqueParticipants   Int             @default(0) @map("unique_participants")
  completedParticipants Int            @default(0) @map("completed_participants")
  actionsCompleted     Int             @default(0) @map("actions_completed")
  rewardsIssued        Int             @default(0) @map("rewards_issued")
  rewardsRedeemed      Int             @default(0) @map("rewards_redeemed")
  videoViews           Int             @default(0) @map("video_views")
  videoCompletions     Int             @default(0) @map("video_completions")
  ctaClicks            Int             @default(0) @map("cta_clicks")
  walletLinksStarted   Int             @default(0) @map("wallet_links_started")
  walletLinksCompleted Int             @default(0) @map("wallet_links_completed")
  metadataJson         Json?           @map("metadata_json")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  campaign             SponsorCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, snapshotDate])
  @@index([campaignId])
  @@map("campaign_analytics_snapshots")
}
