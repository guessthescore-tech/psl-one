generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FAN
  CLUB_ADMIN
  SPONSOR
  PSL_ADMIN
}

enum ConsentPurpose {
  CORE_SERVICE
  MARKETING
  ANALYTICS
  THIRD_PARTY_SHARING
}

enum AuditEvent {
  REGISTER
  LOGIN
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_CONFIRM
  ME_ACCESS
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  saIdHash     String?  @map("sa_id_hash")
  passwordHash String   @map("password_hash")
  role         UserRole @default(FAN)
  dateOfBirth  DateTime @map("date_of_birth") @db.Date
  isVerified   Boolean  @default(false) @map("is_verified")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  consentRecords        ConsentRecord[]
  auditLogs             AuthAuditLog[]
  passwordResets        PasswordResetToken[]
  fanProfile            FanProfile?
  predictions           ScorePrediction[]
  challengesIssued      PeerChallenge[]           @relation("ChallengerChallenges")
  challengesReceived    PeerChallenge[]           @relation("OpponentChallenges")
  wonChallenges         PeerChallenge[]           @relation("WonChallenges")
  ledgerEntries         PredictionPointsLedger[]
  fantasyTeams          FantasyTeam[]
  leagueMemberships     FantasyLeagueMember[]
  createdLeagues        FantasyLeague[]
  gameweekScores        FantasyGameweekScore[]
  playerGameweekScores  FantasyPlayerGameweekScore[]
  fanValueLedger        FanValueLedger[]
  fantasyAutoSubs       FantasyAutoSubstitution[]
  fanAchievements       FanAchievement[]          @relation("FanAchievementOwner")
  awardedAchievements   FanAchievement[]          @relation("FanAchievementAwarder")
  fanBadges               FanBadge[]
  fanRewardReadiness      FanRewardReadiness[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  activityFeedItems       ActivityFeedItem[]      @relation("ActivityFeedItemOwner")
  moderatedActivities     ActivityFeedItem[]      @relation("ActivityFeedItemModerator")
  activityReactions       ActivityReaction[]

  @@map("users")
}

model ConsentRecord {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  purpose    ConsentPurpose
  version    String
  legalBasis String         @map("legal_basis")
  givenAt    DateTime       @default(now()) @map("given_at")
  revokedAt  DateTime?      @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@map("consent_records")
}

model AuthAuditLog {
  id        String     @id @default(uuid())
  userId    String?    @map("user_id")
  event     AuditEvent
  success   Boolean
  userAgent String?    @map("user_agent")
  createdAt DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("auth_audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

// ── Season Status ─────────────────────────────────────────────────────────────

enum SeasonStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ── Competition Format ────────────────────────────────────────────────────────

enum CompetitionFormat {
  LEAGUE
  CUP
  TOURNAMENT
  HYBRID
}

enum StageType {
  LEAGUE
  GROUP
  KNOCKOUT
  FINAL
  PLAYOFF
}

// ── Gameweek ──────────────────────────────────────────────────────────────────

enum GameweekStatus {
  UPCOMING
  OPEN
  LOCKED
  LIVE
  COMPLETED
}

model Gameweek {
  id                   String         @id @default(uuid())
  seasonId             String         @map("season_id")
  name                 String
  slug                 String
  round                Int
  startsAt             DateTime       @map("starts_at")
  endsAt               DateTime       @map("ends_at")
  transferDeadlineAt   DateTime       @map("transfer_deadline_at")
  predictionDeadlineAt DateTime       @map("prediction_deadline_at")
  status               GameweekStatus @default(UPCOMING)
  externalId           String?        @map("external_id")
  source               String?
  sourceUrl            String?        @map("source_url")
  importedAt           DateTime?      @map("imported_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  season               Season                           @relation(fields: [seasonId], references: [id])
  fixtures             Fixture[]
  fantasyTransfers     FantasyTransfer[]
  lineupSnapshots      FantasyGameweekLineupSnapshot[]
  chips                FantasyChip[]
  freeHitSnapshots     FantasyFreeHitSnapshot[]
  h2hFixtures          FantasyHeadToHeadFixture[]
  cupRounds            FantasyCupRound[]
  leagueStarts         FantasyLeague[]                  @relation("LeagueStartsGameweek")
  cupStarts            FantasyCup[]                     @relation("CupStartsGameweek")
  cupEnds              FantasyCup[]                     @relation("CupEndsGameweek")
  gameweekScores       FantasyGameweekScore[]
  playerGameweekScores FantasyPlayerGameweekScore[]
  fanValueLedger       FanValueLedger[]
  fantasyAutoSubs      FantasyAutoSubstitution[]

  @@unique([seasonId, slug])
  @@map("gameweeks")
}

// ── Football Core ─────────────────────────────────────────────────────────────

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  HALF_TIME
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchEventType {
  GOAL
  ASSIST
  OWN_GOAL
  YELLOW_CARD
  RED_CARD
  SECOND_YELLOW
  SUBSTITUTION
  PENALTY_SCORED
  PENALTY_MISSED
  PENALTY_SAVE
  SAVE
  KICKOFF
  HALF_TIME
  SECOND_HALF
  FULL_TIME
  VAR
  INJURY
  OTHER
}

enum LineupStatus {
  STARTING
  SUBSTITUTE
  UNAVAILABLE
  INJURED
  SUSPENDED
  NOT_IN_SQUAD
}

model Competition {
  id                 String            @id @default(uuid())
  name               String
  slug               String            @unique
  logoUrl            String?           @map("logo_url")
  format             CompetitionFormat @default(LEAGUE)
  teamCount          Int?              @map("team_count")
  hasGroups          Boolean           @default(false) @map("has_groups")
  hasKnockouts       Boolean           @default(false) @map("has_knockouts")
  hasHomeAway        Boolean           @default(true) @map("has_home_away")
  usesNeutralVenues  Boolean           @default(false) @map("uses_neutral_venues")
  pointsForWin       Int               @default(3) @map("points_for_win")
  pointsForDraw      Int               @default(1) @map("points_for_draw")
  pointsForLoss      Int               @default(0) @map("points_for_loss")
  source             String?
  externalId         String?           @unique @map("external_id")
  sourceUrl          String?           @map("source_url")
  importedAt         DateTime?         @map("imported_at")

  seasons Season[]
  stages  CompetitionStage[]

  @@map("competitions")
}

model CompetitionStage {
  id            String    @id @default(uuid())
  competitionId String    @map("competition_id")
  name          String
  slug          String
  type          StageType
  order         Int
  startsAt      DateTime? @map("starts_at")
  endsAt        DateTime? @map("ends_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  fixtures    Fixture[]

  @@unique([competitionId, slug])
  @@map("competition_stages")
}

model Season {
  id            String   @id @default(uuid())
  competitionId String   @map("competition_id")
  name          String
  slug          String   @unique
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime @map("end_date") @db.Date
  isActive      Boolean      @default(false) @map("is_active")
  status        SeasonStatus @default(UPCOMING)
  source        String?
  externalId    String?      @map("external_id")
  sourceUrl     String?      @map("source_url")
  importedAt    DateTime?    @map("imported_at")

  competition           Competition               @relation(fields: [competitionId], references: [id])
  fixtures              Fixture[]
  groups                Group[]
  fantasyTeams          FantasyTeam[]
  gameweeks             Gameweek[]
  playerPrices          FantasyPlayerPrice[]
  leagues               FantasyLeague[]
  cups                  FantasyCup[]
  rulesConfig           FantasyRulesConfig?
  gameweekScores        FantasyGameweekScore[]
  fanValueLedger        FanValueLedger[]
  fantasyAutoSubs       FantasyAutoSubstitution[]
  seasonTeams           SeasonTeam[]
  squadRegistrations    SeasonSquadRegistration[]

  @@map("seasons")
}

model Venue {
  id         String    @id @default(uuid())
  name       String
  city       String
  country    String
  capacity   Int?
  externalId String?   @unique @map("external_id")
  source     String?
  sourceUrl  String?   @map("source_url")
  importedAt DateTime? @map("imported_at")

  fixtures Fixture[]

  @@map("venues")
}

model Team {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  shortName  String    @map("short_name")
  logoUrl    String?   @map("logo_url")
  country    String
  externalId String?   @unique @map("external_id")
  source     String?
  sourceUrl  String?   @map("source_url")
  importedAt DateTime? @map("imported_at")

  players              Player[]
  homeFixtures         Fixture[]                @relation("HomeTeam")
  awayFixtures         Fixture[]                @relation("AwayTeam")
  standings            GroupStanding[]
  fans                 FanProfile[]
  matchEvents          MatchEvent[]
  lineups              FixtureLineup[]
  playerMatchStats     FantasyPlayerMatchStat[]
  seasonTeams          SeasonTeam[]
  clubProfile          ClubProfile?
  contentItems         ClubContentItem[]
  shopProducts         ClubShopProduct[]
  experienceStatus     ClubExperienceStatus?
  squadRegistrations   SeasonSquadRegistration[]

  @@map("teams")
}


model Player {
  id          String         @id @default(uuid())
  teamId      String         @map("team_id")
  name        String
  position    PlayerPosition
  nationality String
  dateOfBirth DateTime?      @map("date_of_birth") @db.Date
  number      Int?
  externalId  String?        @map("external_id")
  source      String?
  sourceUrl   String?        @map("source_url")
  importedAt  DateTime?      @map("imported_at")

  team                  Team                         @relation(fields: [teamId], references: [id])
  matchEvents           MatchEvent[]
  relatedMatchEvents    MatchEvent[]                 @relation("MatchEventRelatedPlayer")
  lineups               FixtureLineup[]
  fantasySlots          FantasyTeamPlayer[]
  fantasyLedger         FantasyPointsLedger[]
  transfersOut          FantasyTransfer[]             @relation("RemovedInTransfer")
  transfersIn           FantasyTransfer[]             @relation("AddedInTransfer")
  prices                FantasyPlayerPrice[]
  priceHistory          FantasyPlayerPriceHistory[]
  matchStats            FantasyPlayerMatchStat[]
  gameweekScores        FantasyPlayerGameweekScore[]
  autoSubsOut           FantasyAutoSubstitution[]    @relation("AutoSubOutPlayer")
  autoSubsIn            FantasyAutoSubstitution[]    @relation("AutoSubInPlayer")
  seasonRegistrations   SeasonSquadRegistration[]

  @@map("players")
}

model Fixture {
  id            String        @id @default(uuid())
  seasonId      String        @map("season_id")
  homeTeamId    String        @map("home_team_id")
  awayTeamId    String        @map("away_team_id")
  venueId       String?       @map("venue_id")
  groupId       String?       @map("group_id")
  status        FixtureStatus @default(SCHEDULED)
  kickoffAt     DateTime      @map("kickoff_at")
  homeScore     Int?          @map("home_score")
  awayScore     Int?          @map("away_score")
  currentMinute Int?          @map("current_minute")
  period        String?
  lastUpdatedAt DateTime?     @map("last_updated_at")
  round                String?
  gameweekId           String?  @map("gameweek_id")
  stageId              String?  @map("stage_id")
  isNeutralVenue       Boolean  @default(false) @map("is_neutral_venue")
  legNumber            Int?     @map("leg_number")
  aggregateHomeScore   Int?     @map("aggregate_home_score")
  aggregateAwayScore   Int?     @map("aggregate_away_score")
  extraTimeHomeScore   Int?     @map("extra_time_home_score")
  extraTimeAwayScore   Int?     @map("extra_time_away_score")
  penaltiesHomeScore   Int?     @map("penalties_home_score")
  penaltiesAwayScore   Int?     @map("penalties_away_score")
  startedAt            DateTime? @map("started_at")
  halfTimeAt           DateTime? @map("half_time_at")
  resumedAt            DateTime? @map("resumed_at")
  finishedAt           DateTime? @map("finished_at")
  lastSyncedAt         DateTime? @map("last_synced_at")
  providerSource       String?   @map("provider_source")
  providerFixtureId    String?   @map("provider_fixture_id")
  externalId           String?   @map("external_id")
  source               String?
  sourceUrl            String?   @map("source_url")
  importedAt           DateTime? @map("imported_at")
  assignmentStatus     String    @default("UNASSIGNED") @map("assignment_status")
  assignmentSource     String?   @map("assignment_source")
  assignedAt           DateTime? @map("assigned_at")

  season       Season                   @relation(fields: [seasonId], references: [id])
  homeTeam     Team                     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team                     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue        Venue?                   @relation(fields: [venueId], references: [id])
  group        Group?                   @relation(fields: [groupId], references: [id])
  gameweek     Gameweek?                @relation(fields: [gameweekId], references: [id])
  stage        CompetitionStage?        @relation(fields: [stageId], references: [id], onDelete: SetNull)
  events        MatchEvent[]
  lineups       FixtureLineup[]
  predictions   ScorePrediction[]
  challenges    PeerChallenge[]
  ledgerEntries PredictionPointsLedger[]
  fantasyLedger     FantasyPointsLedger[]
  fantasyMatchStats FantasyPlayerMatchStat[]

  @@map("fixtures")
}

model MatchEvent {
  id               String         @id @default(uuid())
  fixtureId        String         @map("fixture_id")
  teamId           String?        @map("team_id")
  playerId         String?        @map("player_id")
  relatedPlayerId  String?        @map("related_player_id")
  minute           Int
  stoppageMinute   Int?           @map("stoppage_minute")
  period           String?
  eventType        MatchEventType @map("event_type")
  description      String?
  metadata         Json?
  providerEventId  String?        @map("provider_event_id")
  source           String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  fixture       Fixture @relation(fields: [fixtureId], references: [id])
  team          Team?   @relation(fields: [teamId], references: [id])
  player        Player? @relation(fields: [playerId], references: [id])
  relatedPlayer Player? @relation("MatchEventRelatedPlayer", fields: [relatedPlayerId], references: [id])

  @@map("match_events")
}

model FixtureLineup {
  id          String       @id @default(uuid())
  fixtureId   String       @map("fixture_id")
  teamId      String       @map("team_id")
  playerId    String       @map("player_id")
  status      LineupStatus @default(STARTING)
  shirtNumber Int?         @map("shirt_number")
  position    String?
  createdAt   DateTime     @default(now()) @map("created_at")

  fixture Fixture @relation(fields: [fixtureId], references: [id])
  team    Team    @relation(fields: [teamId], references: [id])
  player  Player  @relation(fields: [playerId], references: [id])

  @@unique([fixtureId, teamId, playerId])
  @@map("fixture_lineups")
}

model Group {
  id         String    @id @default(uuid())
  seasonId   String    @map("season_id")
  name       String
  externalId String?   @map("external_id")
  source     String?
  sourceUrl  String?   @map("source_url")
  importedAt DateTime? @map("imported_at")

  season    Season          @relation(fields: [seasonId], references: [id])
  fixtures  Fixture[]
  standings GroupStanding[]

  @@unique([seasonId, name])
  @@map("groups")
}

model GroupStanding {
  id           String @id @default(uuid())
  groupId      String @map("group_id")
  teamId       String @map("team_id")
  played       Int    @default(0)
  won          Int    @default(0)
  drawn        Int    @default(0)
  lost         Int    @default(0)
  goalsFor     Int    @default(0) @map("goals_for")
  goalsAgainst Int    @default(0) @map("goals_against")
  points       Int    @default(0)

  group Group @relation(fields: [groupId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])

  @@unique([groupId, teamId])
  @@map("group_standings")
}

// ── Fan Profile ───────────────────────────────────────────────────────────────

model FanProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  displayName     String?  @map("display_name")
  city            String?
  country         String?
  preferredTeamId String?  @map("preferred_team_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          User                     @relation(fields: [userId], references: [id])
  preferredTeam Team? @relation(fields: [preferredTeamId], references: [id])

  @@map("fan_profiles")
}

// ── Predictions & Peer Challenges ─────────────────────────────────────────────

enum PredictionStatus {
  PENDING
  LOCKED
  WON
  LOST
  SETTLED
  VOID
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  SETTLED
}

model ScorePrediction {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  fixtureId          String           @map("fixture_id")
  predictedHomeScore Int              @map("predicted_home_score")
  predictedAwayScore Int              @map("predicted_away_score")
  pointsAwarded      Int              @default(0) @map("points_awarded")
  status             PredictionStatus @default(PENDING)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  settledAt          DateTime?        @map("settled_at")

  user    User    @relation(fields: [userId], references: [id])
  fixture Fixture @relation(fields: [fixtureId], references: [id])

  challengesAsChallenger PeerChallenge[]          @relation("ChallengerPrediction")
  challengesAsOpponent   PeerChallenge[]          @relation("OpponentPrediction")
  ledgerEntries          PredictionPointsLedger[]

  @@unique([userId, fixtureId])
  @@map("score_predictions")
}

model PeerChallenge {
  id                      String          @id @default(uuid())
  fixtureId               String          @map("fixture_id")
  challengerUserId        String          @map("challenger_user_id")
  opponentUserId          String          @map("opponent_user_id")
  challengerPredictionId  String?         @map("challenger_prediction_id")
  opponentPredictionId    String?         @map("opponent_prediction_id")
  status                  ChallengeStatus @default(PENDING)
  winnerUserId            String?         @map("winner_user_id")
  pointsAwardedChallenger Int             @default(0) @map("points_awarded_challenger")
  pointsAwardedOpponent   Int             @default(0) @map("points_awarded_opponent")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  acceptedAt              DateTime?       @map("accepted_at")
  settledAt               DateTime?       @map("settled_at")

  fixture              Fixture          @relation(fields: [fixtureId], references: [id])
  challenger           User             @relation("ChallengerChallenges", fields: [challengerUserId], references: [id])
  opponent             User             @relation("OpponentChallenges", fields: [opponentUserId], references: [id])
  winner               User?            @relation("WonChallenges", fields: [winnerUserId], references: [id])
  challengerPrediction ScorePrediction? @relation("ChallengerPrediction", fields: [challengerPredictionId], references: [id])
  opponentPrediction   ScorePrediction? @relation("OpponentPrediction", fields: [opponentPredictionId], references: [id])
  ledgerEntries        PredictionPointsLedger[]

  @@map("peer_challenges")
}

model PredictionPointsLedger {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  fixtureId    String   @map("fixture_id")
  predictionId String?  @map("prediction_id")
  challengeId  String?  @map("challenge_id")
  points       Int
  reason       String
  createdAt    DateTime @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id])
  fixture    Fixture          @relation(fields: [fixtureId], references: [id])
  prediction ScorePrediction? @relation(fields: [predictionId], references: [id])
  challenge  PeerChallenge?   @relation(fields: [challengeId], references: [id])

  @@map("prediction_points_ledger")
}

// ── Fantasy ───────────────────────────────────────────────────────────────────

enum FantasySquadRole {
  STARTER
  SUBSTITUTE
}

enum FantasyChipType {
  BENCH_BOOST
  FREE_HIT
  TRIPLE_CAPTAIN
  WILDCARD
}

enum FantasyChipStatus {
  AVAILABLE
  ACTIVE
  USED
  CANCELLED
  EXPIRED
}

enum FantasyLeagueType {
  PRIVATE
  PUBLIC
  GLOBAL
}

enum FantasyLeagueScoringType {
  CLASSIC
  HEAD_TO_HEAD
}

enum FantasyLeagueMemberRole {
  OWNER
  MEMBER
}

enum FantasyHeadToHeadStatus {
  SCHEDULED
  COMPLETE
  VOID
}

enum FantasyCupTieStatus {
  SCHEDULED
  COMPLETE
  VOID
}

enum FantasyCupStatus {
  UPCOMING
  ACTIVE
  COMPLETE
}

enum FantasyAutoSubstitutionStatus {
  APPLIED
  SKIPPED_NO_ELIGIBLE_SUB
  SKIPPED_FORMATION_INVALID
  SKIPPED_BENCH_PLAYER_DID_NOT_PLAY
  SKIPPED_GOALKEEPER_ONLY
  SKIPPED_STARTER_PLAYED
}

model FantasyTeam {
  id                     String   @id @default(uuid())
  userId                 String   @map("user_id")
  seasonId               String   @map("season_id")
  name                   String   @default("My Fantasy Team")
  formation              String?
  totalPoints            Int      @default(0) @map("total_points")
  freeTransfersAvailable Int      @default(1) @map("free_transfers_available")
  hasPassedFirstDeadline Boolean  @default(false) @map("has_passed_first_deadline")
  totalTransferDeductions Int     @default(0) @map("total_transfer_deductions")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user                 User                           @relation(fields: [userId], references: [id])
  season               Season                         @relation(fields: [seasonId], references: [id])
  players              FantasyTeamPlayer[]
  ledger               FantasyPointsLedger[]
  transfers            FantasyTransfer[]
  chips                FantasyChip[]
  freeHitSnapshots     FantasyFreeHitSnapshot[]
  lineupSnapshots      FantasyGameweekLineupSnapshot[]
  h2hFixturesHome      FantasyHeadToHeadFixture[]      @relation("H2HHome")
  h2hFixturesAway      FantasyHeadToHeadFixture[]      @relation("H2HAway")
  cupTiesHome          FantasyCupTie[]                 @relation("CupTieHome")
  cupTiesAway          FantasyCupTie[]                 @relation("CupTieAway")
  leagueMemberships    FantasyLeagueMember[]
  gameweekScores       FantasyGameweekScore[]
  playerGameweekScores FantasyPlayerGameweekScore[]
  autoSubs             FantasyAutoSubstitution[]

  @@unique([userId, seasonId])
  @@map("fantasy_teams")
}

model FantasyTeamPlayer {
  id            String           @id @default(uuid())
  fantasyTeamId String           @map("fantasy_team_id")
  playerId      String           @map("player_id")
  squadRole     FantasySquadRole @map("squad_role")
  benchSlot     Int?             @map("bench_slot")
  isCaptain     Boolean          @default(false) @map("is_captain")
  isViceCaptain Boolean          @default(false) @map("is_vice_captain")
  position      PlayerPosition
  lockedAt      DateTime?        @map("locked_at")
  addedAt       DateTime         @default(now()) @map("added_at")

  fantasyTeam FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  player      Player      @relation(fields: [playerId], references: [id])

