  id                      String @id @default(uuid())
  achievementDefinitionId String @map("achievement_definition_id")
  badgeDefinitionId       String @map("badge_definition_id")
  createdAt               DateTime @default(now()) @map("created_at")

  achievement AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id])
  badge       BadgeDefinition       @relation(fields: [badgeDefinitionId], references: [id])

  @@unique([achievementDefinitionId, badgeDefinitionId])
  @@map("achievement_badges")
}

model FanAchievement {
  id                      String            @id @default(uuid())
  userId                  String            @map("user_id")
  achievementDefinitionId String            @map("achievement_definition_id")
  progress                Int               @default(0)
  target                  Int?
  status                  AchievementStatus @default(LOCKED)
  unlockedAt              DateTime?         @map("unlocked_at")
  awardedByUserId         String?           @map("awarded_by_user_id")
  revokedAt               DateTime?         @map("revoked_at")
  revokeReason            String?           @map("revoke_reason")
  metadataJson            Json?             @map("metadata_json")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  user       User                  @relation("FanAchievementOwner", fields: [userId], references: [id])
  awardedBy  User?                 @relation("FanAchievementAwarder", fields: [awardedByUserId], references: [id])
  definition AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id])
  fanBadges  FanBadge[]

  @@unique([userId, achievementDefinitionId])
  @@index([userId, status])
  @@map("fan_achievements")
}

model FanBadge {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  badgeDefinitionId String    @map("badge_definition_id")
  fanAchievementId  String?   @map("fan_achievement_id")
  awardedAt         DateTime  @default(now()) @map("awarded_at")
  revokedAt         DateTime? @map("revoked_at")
  revokeReason      String?   @map("revoke_reason")
  isDisplayed       Boolean   @default(true) @map("is_displayed")
  metadataJson      Json?     @map("metadata_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id])
  badge          BadgeDefinition @relation(fields: [badgeDefinitionId], references: [id])
  fanAchievement FanAchievement? @relation(fields: [fanAchievementId], references: [id])

  @@unique([userId, badgeDefinitionId])
  @@index([userId])
  @@map("fan_badges")
}

// ── Rewards Readiness ─────────────────────────────────────────────────────────

enum RewardReadinessStatus {
  ELIGIBLE
  INELIGIBLE
  PENDING_EVALUATION
}

enum RewardReadinessCategory {
  FANTASY
  PREDICTIONS
  CHALLENGES
  SPONSOR_READY
  FAN_VALUE
  LOYALTY
  PLATFORM
}

model RewardReadinessDefinition {
  id          String                  @id @default(uuid())
  slug        String                  @unique
  name        String
  description String
  category    RewardReadinessCategory
  isEnabled   Boolean                 @default(true) @map("is_enabled")
  sortOrder   Int                     @default(0) @map("sort_order")

  // Eligibility requirements — all non-null/true conditions must be met
  minFanValuePoints          Int?     @map("min_fan_value_points")
  requiredAchievementSlugs   String[] @map("required_achievement_slugs")
  requiredBadgeSlugs         String[] @map("required_badge_slugs")
  requiresFantasyTeam        Boolean  @default(false) @map("requires_fantasy_team")
  requiresPredictionActivity Boolean  @default(false) @map("requires_prediction_activity")
  requiresChallengeActivity  Boolean  @default(false) @map("requires_challenge_activity")

  // Display copy
  unlockHint        String? @map("unlock_hint")
  sponsorName       String? @map("sponsor_name")
  notRedeemableNote String  @default("This reward opportunity is not yet redeemable. Fan Value points have no cash value.") @map("not_redeemable_note")

  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  fanReadiness FanRewardReadiness[]

  @@map("reward_readiness_definitions")
}

model FanRewardReadiness {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  definitionId String                @map("definition_id")
  status       RewardReadinessStatus @default(PENDING_EVALUATION)
  evaluatedAt  DateTime?             @map("evaluated_at")

  metRequirementsJson   Json? @map("met_requirements_json")
  unmetRequirementsJson Json? @map("unmet_requirements_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User                      @relation(fields: [userId], references: [id])
  definition RewardReadinessDefinition @relation(fields: [definitionId], references: [id])

  @@unique([userId, definitionId])
  @@index([userId, status])
  @@map("fan_reward_readiness")
}

// ── Notifications & Alerts ────────────────────────────────────────────────────

enum NotificationType {
  SYSTEM
  FANTASY_DEADLINE
  FANTASY_RESULT
  PREDICTION_LOCK
  PREDICTION_RESULT
  CHALLENGE_INVITE
  CHALLENGE_RESULT
  ACHIEVEMENT_UNLOCKED
  REWARD_ELIGIBLE
  LIVE_MATCH_ALERT
  ADMIN_BROADCAST
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  IN_APP
  PUSH_READY
  EMAIL_READY
  SMS_READY
}

enum NotificationDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  SKIPPED
}

model Notification {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  type        NotificationType
  title       String
  body        String
  status      NotificationStatus   @default(UNREAD)
  priority    NotificationPriority @default(NORMAL)
  sourceType  String?              @map("source_type")
  sourceId    String?              @map("source_id")
  actionUrl   String?              @map("action_url")
  metadataJson Json?               @map("metadata_json")
  readAt      DateTime?            @map("read_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  user         User                      @relation(fields: [userId], references: [id])
  deliveryLogs NotificationDeliveryLog[]

  @@unique([userId, sourceType, sourceId])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ── Social Activity Feed ───────────────────────────────────────────────────────

enum ActivityFeedType {
  SYSTEM
  ACHIEVEMENT_UNLOCKED
  BADGE_EARNED
  FANTASY_RESULT
  PREDICTION_RESULT
  CHALLENGE_CREATED
  CHALLENGE_RESULT
  REWARD_ELIGIBLE
  LIVE_MATCH_ALERT
  FAN_VALUE_MILESTONE
  ADMIN_POST
}

enum ActivityVisibility {
  PUBLIC
  PRIVATE
  ADMIN_ONLY
}

enum ActivityStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum ActivityReactionType {
  LIKE
  FIRE
  CLAP
  TROPHY
  BALL
}

model ActivityFeedItem {
  id              String             @id @default(uuid())
  userId          String?            @map("user_id")
  type            ActivityFeedType
  title           String
  body            String
  visibility      ActivityVisibility @default(PUBLIC)
  status          ActivityStatus     @default(ACTIVE)
  sourceType      String?            @map("source_type")
  sourceId        String?            @map("source_id")
  actionUrl       String?            @map("action_url")
  metadataJson    Json?              @map("metadata_json")
  occurredAt      DateTime           @default(now()) @map("occurred_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  hiddenAt        DateTime?          @map("hidden_at")
  hiddenByUserId  String?            @map("hidden_by_user_id")
  hiddenReason    String?            @map("hidden_reason")

  user      User?              @relation("ActivityFeedItemOwner", fields: [userId], references: [id])
  hiddenBy  User?              @relation("ActivityFeedItemModerator", fields: [hiddenByUserId], references: [id])
  reactions ActivityReaction[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([occurredAt(sort: Desc)])
  @@map("activity_feed_items")
}

model ActivityReaction {
  id                 String               @id @default(uuid())
  activityFeedItemId String               @map("activity_feed_item_id")
  userId             String               @map("user_id")
  reactionType       ActivityReactionType @map("reaction_type")
  createdAt          DateTime             @default(now()) @map("created_at")

  activityFeedItem ActivityFeedItem @relation(fields: [activityFeedItemId], references: [id])
  user             User             @relation(fields: [userId], references: [id])

  @@unique([activityFeedItemId, userId, reactionType])
  @@index([userId])
  @@map("activity_reactions")
}

model NotificationPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  inAppEnabled         Boolean  @default(true) @map("in_app_enabled")
  fantasyEnabled       Boolean  @default(true) @map("fantasy_enabled")
  predictionsEnabled   Boolean  @default(true) @map("predictions_enabled")
  challengesEnabled    Boolean  @default(true) @map("challenges_enabled")
  achievementsEnabled  Boolean  @default(true) @map("achievements_enabled")
  rewardsEnabled       Boolean  @default(true) @map("rewards_enabled")
  systemEnabled        Boolean  @default(true) @map("system_enabled")
  marketingEnabled     Boolean  @default(false) @map("marketing_enabled")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model NotificationDeliveryLog {
  id             String                     @id @default(uuid())
  notificationId String?                    @map("notification_id")
  userId         String                     @map("user_id")
  channel        NotificationChannel
  provider       String
  status         NotificationDeliveryStatus
  errorMessage   String?                    @map("error_message")
  metadataJson   Json?                      @map("metadata_json")
  attemptedAt    DateTime                   @default(now()) @map("attempted_at")
  createdAt      DateTime                   @default(now()) @map("created_at")

  notification Notification? @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@index([userId, attemptedAt(sort: Desc)])
  @@map("notification_delivery_logs")
}

// ── Club Experience ────────────────────────────────────────────────────────────

enum SeasonTeamStatus {
  ACTIVE
  PROVISIONAL
  PROMOTED
  RELEGATED
  WITHDRAWN
  NEEDS_REVIEW
}

enum SeasonTeamSource {
  MANUAL
  IMPORT
  OFFICIAL
  PLACEHOLDER
}

enum ClubProfileStatus {
  DRAFT
  READY
  PUBLISHED
}

enum ClubContentType {
  NEWS
  VIDEO
  ANNOUNCEMENT
}

enum ClubContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShopProductCategory {
  HOME_KIT
  AWAY_KIT
  THIRD_KIT
  TRAINING_WEAR
  LIFESTYLE
  ACCESSORIES
  SOUVENIRS
  KIDS
}

enum ShopProductAvailability {
  COMING_SOON
  AVAILABLE_SOON
  UNAVAILABLE
}

enum ShopProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShopCommerceStatus {
  CATALOGUE_ONLY
  COMMERCE_READY_FOR_SPRINT_3
}

enum SquadRegistrationStatus {
  PROVISIONAL
  CONFIRMED
  NEEDS_REVIEW
  REMOVED
}

enum SquadRegistrationSource {
  MANUAL
  IMPORT
  OFFICIAL
  PLACEHOLDER
}

model SeasonTeam {
  id        String           @id @default(uuid())
  seasonId  String           @map("season_id")
  teamId    String           @map("team_id")
  status    SeasonTeamStatus @default(PROVISIONAL)
  source    SeasonTeamSource @default(PLACEHOLDER)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  season Season @relation(fields: [seasonId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([seasonId, teamId])
  @@index([seasonId, status])
  @@map("season_teams")
}

model ClubProfile {
  id             String            @id @default(uuid())
  teamId         String            @unique @map("team_id")
  foundedYear    Int?              @map("founded_year")
  city           String?
  province       String?
  country        String            @default("South Africa")
  websiteUrl     String?           @map("website_url")
  ticketingUrl   String?           @map("ticketing_url")
  shopUrl        String?           @map("shop_url")
  description    String?
  heroImageUrl   String?           @map("hero_image_url")
  crestUrl       String?           @map("crest_url")
  primaryColor   String?           @map("primary_color")
  secondaryColor String?           @map("secondary_color")
  profileStatus  ClubProfileStatus @default(DRAFT) @map("profile_status")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("club_profiles")
}

model ClubContentItem {
  id          String            @id @default(uuid())
  teamId      String            @map("team_id")
  type        ClubContentType
  title       String
  summary     String?
  imageUrl    String?           @map("image_url")
  videoUrl    String?           @map("video_url")
  externalUrl String?           @map("external_url")
  status      ClubContentStatus @default(DRAFT)
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, status])
  @@map("club_content_items")
}

model ClubShopProduct {
  id             String                  @id @default(uuid())
  teamId         String                  @map("team_id")
  name           String
  slug           String
  category       ShopProductCategory
  description    String?
  imageUrl       String?                 @map("image_url")
  priceDisplay   String?                 @map("price_display")
  currencyCode   String?                 @map("currency_code")
  availability   ShopProductAvailability @default(COMING_SOON)
  featured       Boolean                 @default(false)
  status         ShopProductStatus       @default(DRAFT)
  commerceStatus ShopCommerceStatus      @default(CATALOGUE_ONLY) @map("commerce_status")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@unique([teamId, slug])
  @@index([teamId, status])
  @@map("club_shop_products")
}

model ClubExperienceStatus {
  id             String    @id @default(uuid())
  teamId         String    @unique @map("team_id")
  profileReady   Boolean   @default(false) @map("profile_ready")
  squadReady     Boolean   @default(false) @map("squad_ready")
  fixturesReady  Boolean   @default(false) @map("fixtures_ready")
  venueReady     Boolean   @default(false) @map("venue_ready")
  ticketsReady   Boolean   @default(false) @map("tickets_ready")
  shopfrontReady Boolean   @default(false) @map("shopfront_ready")
  catalogueReady Boolean   @default(false) @map("catalogue_ready")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  reviewNotes    String?   @map("review_notes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("club_experience_statuses")
}

model SeasonSquadRegistration {
  id           String                  @id @default(uuid())
  seasonId     String                  @map("season_id")
  teamId       String                  @map("team_id")
  playerId     String                  @map("player_id")
  status       SquadRegistrationStatus @default(PROVISIONAL)
  shirtNumber  Int?                    @map("shirt_number")
  source       SquadRegistrationSource @default(PLACEHOLDER)
  registeredAt DateTime?               @map("registered_at")
  removedAt    DateTime?               @map("removed_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  season Season @relation(fields: [seasonId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([seasonId, playerId])
  @@index([seasonId, teamId])
  @@map("season_squad_registrations")
}
