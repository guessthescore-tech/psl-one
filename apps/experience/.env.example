# PSL One — Experience App Environment Variables
# Copy this to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.

# ── Data mode ───────────────────────────────────────────────────────────────
# DESIGN_REVIEW_DATA: uses local design-review mock data (default for preview)
# LIVE_BETA_DATA: calls the real PSL One API (requires NEXT_PUBLIC_API_BASE_URL)
NEXT_PUBLIC_DATA_MODE=DESIGN_REVIEW_DATA

# ── API base URL ─────────────────────────────────────────────────────────────
# The NestJS backend base URL. This is a hostname only — NOT a secret.
# Never add actual API keys or secrets to NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Environment label (shown in Design Review banner) ────────────────────────
NEXT_PUBLIC_ENVIRONMENT_LABEL=local

# ── Analytics (preview only — not wired to production analytics) ─────────────
# Set to "true" to enable preview analytics event logging to console
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# ── Preview protection ────────────────────────────────────────────────────────
# Vercel password protection is configured at the project level in Vercel dashboard.
# No env var required here for Vercel protection.

# ── Notes ────────────────────────────────────────────────────────────────────
# Vercel environment variables are set in the Vercel project dashboard.
# See docs/handover/SPRINT-4-DEPLOY-GUIDE.md for full deployment instructions.
