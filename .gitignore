# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
out/
build/

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example
!.env.beta.example
!.env.compose.example
apps/*/.env
apps/*/.env.*
!apps/*/.env.example

# Secrets and key files
*.secret
*.secrets

# Screenshots (may contain sensitive info)
screenshots/

# Terraform state and planning artefacts — never commit
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/.terraform.lock.hcl
**/terraform.tfvars
**/*.tfplan

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Playwright
playwright-report/
test-results/

# Logs
*.log
logs/

# Prisma
# Keep migration files, exclude generated client output
**/node_modules/.prisma/

# Local settings
.claude/settings.local.json
# Claude Code session memory — local only, contains absolute paths and session context
.claude/projects/

# Turbo cache
.turbo/

# Vercel project linking (created by vercel CLI at repo root)
.vercel/

# Local AI design skills
.agents/skills/
.claude/skills/
skills-lock.json
