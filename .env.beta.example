# PSL One Beta — Environment variable template.
# This file is committed to the repo as a documentation reference only.
# Copy to .env.beta on the EC2 instance. Do NOT commit .env.beta.
# Secrets are populated by infra/beta/bootstrap-ec2.sh from SSM Parameter Store.
# All values below are PLACEHOLDER only. IMAGE_STATUS=PLACEHOLDER.

# ── AWS identity (set by bootstrap-ec2.sh) ────────────────────────────────────
AWS_REGION=af-south-1
ECR_REGISTRY=844513166932.dkr.ecr.af-south-1.amazonaws.com

# ── Image URIs (immutable full-SHA tags — no 'latest', no short tags) ─────────
# Repositories: psl-one-beta-api | psl-one-beta-api-migrator | psl-one-beta-web
# Updated by the deploy workflow via SSM put-parameter and sed in deploy step.
API_IMAGE_URI=844513166932.dkr.ecr.af-south-1.amazonaws.com/psl-one-beta-api:PLACEHOLDER
MIGRATION_IMAGE_URI=844513166932.dkr.ecr.af-south-1.amazonaws.com/psl-one-beta-api-migrator:PLACEHOLDER
WEB_IMAGE_URI=844513166932.dkr.ecr.af-south-1.amazonaws.com/psl-one-beta-web:PLACEHOLDER

# ── Deployment metadata ────────────────────────────────────────────────────────
GIT_SHA=0000000000000000000000000000000000000000
BUILD_TIMESTAMP=1970-01-01T00:00:00Z

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Populated from SSM /psl-one/beta/postgres-user, /psl-one/beta/postgres-db,
# and /psl-one/beta/postgres-password at boot. Passwords not logged.
POSTGRES_USER=psl_admin
POSTGRES_PASSWORD=REPLACE_FROM_SSM
POSTGRES_DB=psl_beta
DATABASE_URL=postgresql://psl_admin:REPLACE_FROM_SSM@postgres:5432/psl_beta

# ── Application secrets ────────────────────────────────────────────────────────
# Populated from SSM /psl-one/beta/jwt-secret at boot.
JWT_SECRET=REPLACE_FROM_SSM
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://api.staging.pslone.co.za,http://staging.pslone.co.za

# ── Caddy virtual hosts ────────────────────────────────────────────────────────
# Mode A (restricted internal testing — default):
#   Use these hostname defaults. Testers add to /etc/hosts:
#     <EC2-IP>  api.staging.pslone.co.za  staging.pslone.co.za
#   Do NOT set API_DOMAIN or WEB_DOMAIN to the raw EC2 IP.
#   Caddy serves HTTP only (no ACME for IP addresses).
#   Restrict BOTH port 80 and 443 to reviewer CIDRs via allowed_beta_cidrs in Terraform.
#
# Mode B (approved public HTTPS — requires explicit owner approval):
#   Create DNS A records: api.staging.pslone.co.za and staging.pslone.co.za → EC2 IP.
#   Set CADDY_ACME_EMAIL. Open allowed_beta_cidrs = ["0.0.0.0/0"] in Terraform.
#   Rebuild web image with NEXT_PUBLIC_API_BASE_URL=https://api.staging.pslone.co.za.
#   Enable Elastic IP (create_elastic_ip = true) for stable ACME binding.
API_DOMAIN=api.staging.pslone.co.za
WEB_DOMAIN=staging.pslone.co.za
CADDY_ACME_EMAIL=
