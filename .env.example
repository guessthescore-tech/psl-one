# =============================================================
# PSL One — Environment Variables Example
# Copy to .env.local for local development
# NEVER commit .env or .env.local to git
# In production: all secrets live in AWS Secrets Manager
# =============================================================

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCOUNT_ID=

# ── Cognito ──────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ── Database (per-service, override in service .env) ─────────
# Format: postgresql://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psl_identity_dev

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=psl-local
KAFKA_GROUP_ID=psl-local-group
# For MSK Serverless (production): set KAFKA_SASL_MECHANISM=AWS_MSK_IAM

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Provider API Keys (server-side only — NEVER expose as NEXT_PUBLIC_*) ──────
# Do not commit real key values. Place actual keys in apps/api/.env locally.
# In staging: store in AWS SSM Parameter Store only if owner authorizes.
#
# SPORTMONKS_API_KEY: DEPRECATED — Sportmonks removed from active provider strategy (Sprint 10).
# Adapter retained for reference; key should be left empty or removed from .env.
# See docs/data/SPRINT-10-ACTIVE-PROVIDER-STRATEGY.md for replacement strategy.
SPORTMONKS_API_KEY=
#
# SPORTSDATAIO_SOCCER_API_KEY: Secondary candidate — PSL not confirmed on current trial.
# See docs/data/SPRINT-11-PROVIDER-SHORTLIST.md for evaluation status.
SPORTSDATAIO_SOCCER_API_KEY=
#
# API_FOOTBALL_KEY: Primary candidate (Sprint 11). api-sports.io / api-football.com.
# PSL league ID 288. Must be set together with DATA_PROVIDER=api-football to activate.
# Never set as NEXT_PUBLIC_* — server-side only.
# See docs/data/SPRINT-11-PROVIDER-DECISION.md for wiring instructions.
API_FOOTBALL_KEY=
#
# FOOTBALL_DATA_API_KEY: World Cup beta candidate (Sprint 12). football-data.org.
# WC competition code. PSL is NOT available on football-data.org.
# Must be set together with DATA_PROVIDER=football-data-org to activate.
# Never set as NEXT_PUBLIC_* — server-side only. Do NOT use Odds Add-On.
# See docs/data/SPRINT-12-FOOTBALL-DATA-ORG-VALIDATION.md.
FOOTBALL_DATA_API_KEY=
#
# PARSE_API_KEY: Parse psl.co.za API — PSL official-site provider candidate (Sprint 14).
# Parse.bot wraps public psl.co.za data; not an official PSL developer API.
# PARSE_API_KEY is server-side only — never use NEXT_PUBLIC_PARSE_API_KEY.
# Must be set together with DATA_PROVIDER=parse-psl to activate globally,
# or PARSE_API_KEY alone activates the PSL route in ProviderRouterService.
# See docs/data/SPRINT-14-PROVIDER-STRATEGY.md.
PARSE_API_KEY=
#
# DATA_PROVIDER: Explicit provider selection flag (Sprint 11+).
# Leave blank to use NoOpAdapter (safe default).
# Valid values: api-football | football-data-org | parse-psl | (blank = NoOp)
DATA_PROVIDER=
#
# DATA_PROVIDER_ROUTING_ENABLED: Enable per-competition routing via ProviderRouterService (Sprint 13).
# Leave false until both API keys are validated live.
# Valid values: true | false | (blank = false)
DATA_PROVIDER_ROUTING_ENABLED=false

# ── Email (SES in production) ────────────────────────────────
SES_FROM_ADDRESS=noreply@pslone.co.za
SES_REGION=af-south-1

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_SERVICE_NAME=psl-identity
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-generate-a-real-secret-at-least-32-chars

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TENANT_ID=psl

# ── Next.js (apps only) ──────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql
