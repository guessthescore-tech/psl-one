# =============================================================
# PSL One — Environment Variables Example
# Copy to .env.local for local development
# NEVER commit .env or .env.local to git
# In production: all secrets live in AWS Secrets Manager
# =============================================================

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCOUNT_ID=

# ── Cognito ──────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ── Database (per-service, override in service .env) ─────────
# Format: postgresql://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psl_identity_dev

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=psl-local
KAFKA_GROUP_ID=psl-local-group
# For MSK Serverless (production): set KAFKA_SASL_MECHANISM=AWS_MSK_IAM

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Keys (rotate regularly) ──────────────────────────────
API_FOOTBALL_KEY=

# ── Email (SES in production) ────────────────────────────────
SES_FROM_ADDRESS=noreply@pslone.co.za
SES_REGION=af-south-1

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_SERVICE_NAME=psl-identity
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-generate-a-real-secret-at-least-32-chars

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TENANT_ID=psl

# ── Next.js (apps only) ──────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql
